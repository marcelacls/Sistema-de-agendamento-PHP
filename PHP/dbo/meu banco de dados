CREATE DATABASE Clinica Dentaria;

USE Clinica Dentaria;

CREATE TABLE Pacientes (
 id INT AUTO_INCREMENT PRIMARY KEY,
 nome VARCHAR(100),
 telefone VARCHAR(20),
 email VARCHAR(100)
);

CREATE TABLE Dentista (
 id INT AUTO_INCREMENT PRIMARY KEY,
 nome VARCHAR(100),
 especialidade VARCHAR(100)
);

CREATE TABLE Consultas (
 id INT AUTO_INCREMENT PRIMARY KEY,
 paciente_id INT,
 dentista_id INT,
 data DATE,
 hora TIME
);